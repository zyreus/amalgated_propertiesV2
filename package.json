{
  "name": "amalgated-properties-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Premium corporate real estate website for Amalgated Properties & Management Corporation",
  "scripts": {
    "dev": "vite --config frontend/vite.config.mts --host 0.0.0.0",
    "dev:full": "concurrently -n vite,server -c green,blue \"npm run dev\" \"npm run server\"",
    "build": "vite build --config frontend/vite.config.mts",
    "preview": "vite preview --config frontend/vite.config.mts",
    "db:mysql:init": "node scripts/init-mysql.js",
    "server": "node backend/server.js",
    "postinstall": "node scripts/patch-pm2-windows.cjs",
    "pm2:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/free-ports.ps1 && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pm2.ps1 start ecosystem.config.cjs",
    "pm2:start:all": "npm run pm2:start",
    "pm2:restart": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pm2.ps1 restart all",
    "pm2:reload": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pm2.ps1 reload all",
    "pm2:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pm2.ps1 stop all",
    "pm2:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pm2.ps1 status",
    "pm2:logs": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pm2.ps1 logs",
    "domain:hosts": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-local-domain.ps1",
    "domain:apache": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/enable-apache-domain.ps1"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.1",
    "framer-motion": "^12.39.0",
    "groq-sdk": "^0.37.0",
    "gsap": "^3.14.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.16.0",
    "mysql2": "^3.22.3",
    "nodemailer": "^8.0.1",
    "openai": "^6.27.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react-swc": "^3.6.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "pm2": "^7.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "vite": "^6.0.0"
  }
}
